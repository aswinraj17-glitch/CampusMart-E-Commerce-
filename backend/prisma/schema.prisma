datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 Int      @id @default(autoincrement())
  name               String
  email              String   @unique
  password           String
  role               String   @default("buyer") // buyer, seller, admin
  phone              String?
  department         String?  // for verification and recommendations
  semester           Int?     // for recommendations
  verificationStatus String   @default("Pending") // Pending, Verified, Rejected
  createdAt          DateTime @default(now())
  
  // Relations
  products                 Product[]                 @relation("SellerProducts")
  carts                    Cart[]
  orders                   Order[]
  addresses                Address[]
  verification             CollegeVerification?
  wishlists                Wishlist[]
  notifications            Notification[]
  
  // Chat relations
  buyerChats               Chat[]                    @relation("BuyerChats")
  sellerChats              Chat[]                    @relation("SellerChats")
  sentMessages             Message[]                 @relation("SentMessages")
  
  // Swaps relations
  sentSwaps                ExchangeRequest[]         @relation("SentExchangeRequests")
  receivedSwaps            ExchangeRequest[]         @relation("ReceivedExchangeRequests")

  // Reviews relations
  reviewsWritten           Review[]                  @relation("Reviewer")
  reviewsReceived          Review[]                  @relation("SellerReviews")
}

model CollegeVerification {
  userId        Int      @id
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  collegeName   String
  department    String
  yearOfStudy   Int
  collegeEmail  String?
  idCardUrl     String   @db.Text
  status        String   @default("Pending") // Pending, Verified, Rejected
  rejectReason  String?  @db.Text
  createdAt     DateTime @default(now())
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  products  Product[]
}

model Product {
  id             Int               @id @default(autoincrement())
  name           String
  description    String?           @db.Text
  price          Decimal           @db.Decimal(10, 2)
  imageUrl       String?           @db.Text
  imagesJson     String?           @db.LongText
  condition      String            @default("New") // New, Used
  collegeName    String?
  contactDetails String?
  listingType    String            @default("Sell") // Sell, Exchange, SellOrExchange, Donate
  department     String?
  semester       Int?
  isAvailable    Boolean           @default(true)
  
  category       Category          @relation(fields: [categoryId], references: [id])
  categoryId     Int
  seller         User              @relation("SellerProducts", fields: [sellerId], references: [id])
  sellerId       Int
  createdAt      DateTime          @default(now())
  
  // Relations
  cartItems            CartItem[]
  orderItems           OrderItem[]
  reviews              Review[]
  wishlists            Wishlist[]
  chats                Chat[]
  exchangeProposed     ExchangeRequest[] @relation("ProposedProduct")
  exchangeRequested    ExchangeRequest[] @relation("RequestedProduct")
}

model Cart {
  id        Int        @id @default(autoincrement())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int        @unique // 1 cart per user
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId    Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  quantity  Int      @default(1)
  
  @@unique([cartId, productId])
}

model Order {
  id          Int         @id @default(autoincrement())
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  status      String      @default("Order Placed") // Order Placed, Seller Confirmed, Packed, Shipped, Out for Delivery, Delivered
  totalAmount Decimal     @db.Decimal(10, 2)
  createdAt   DateTime    @default(now())
  
  // Shipping Address Snapshot
  fullName       String
  phone          String
  email          String
  addressLine    String
  city           String
  state          String
  zipCode        String
  deliveryDate   DateTime?
  
  // Relations
  items       OrderItem[]
  payments    Payment[]
  meetup      Meetup?
}

model OrderItem {
  id            Int      @id @default(autoincrement())
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       Int
  product       Product  @relation(fields: [productId], references: [id])
  productId     Int
  quantity      Int      @default(1)
  productName   String
  productPrice  Decimal  @db.Decimal(10, 2)
  productImage  String?  @db.Text
}

model Address {
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  fullName    String
  phone       String
  addressLine String
  city        String
  state       String
  zipCode     String
  isDefault   Boolean  @default(false)
}

model Payment {
  id            Int      @id @default(autoincrement())
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       Int
  paymentMethod String   @default("COD") // COD, Card, UPI
  amount        Decimal  @db.Decimal(10, 2)
  status        String   @default("Pending") // Pending, Completed, Failed
  transactionId String?  @unique
  createdAt     DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId Int?
  
  reviewer  User     @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewerId Int
  
  seller    User     @relation("SellerReviews", fields: [sellerId], references: [id], onDelete: Cascade)
  sellerId  Int
  
  rating    Int      @default(5) // 1 to 5
  comment   String?  @db.Text
  createdAt DateTime @default(now())
}

model CollegeVerificationUploads {
  id        Int      @id @default(autoincrement())
  filename  String
  createdAt DateTime @default(now())
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Chat {
  id        Int       @id @default(autoincrement())
  buyerId   Int
  buyer     User      @relation("BuyerChats", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId  Int
  seller    User      @relation("SellerChats", fields: [sellerId], references: [id], onDelete: Cascade)
  productId Int?
  product   Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  messages  Message[]
  createdAt DateTime  @default(now())

  @@unique([buyerId, sellerId, productId])
}

model Message {
  id        Int      @id @default(autoincrement())
  chatId    Int
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  Int
  sender    User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  text      String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ExchangeRequest {
  id                 Int      @id @default(autoincrement())
  senderId           Int
  sender             User     @relation("SentExchangeRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId         Int
  receiver           User     @relation("ReceivedExchangeRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  proposedProductId  Int
  proposedProduct    Product  @relation("ProposedProduct", fields: [proposedProductId], references: [id], onDelete: Cascade)
  requestedProductId Int
  requestedProduct   Product  @relation("RequestedProduct", fields: [requestedProductId], references: [id], onDelete: Cascade)
  status             String   @default("Pending") // Pending, Accepted, Rejected
  createdAt          DateTime @default(now())
}

model Meetup {
  id        Int      @id @default(autoincrement())
  orderId   Int      @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  option    String   // Campus, Hostel, Home
  location  String
  date      String
  time      String
  createdAt DateTime @default(now())
}
